#!/usr/bin/env bash
# bin/forge-build — Generic Forge v2 build pipeline.
#
# Reads tool-neutral sources from core/ and emits a single universal payload:
#   build/AGENTS.md          — thin pointer file (<150 lines, <32 KiB)
#   build/.agents/skills/    — Open Agent Skills standard path (Anthropic, Dec 2025;
#                              cross-tool standard since Jan 2026)
#   build/.agents/rules/     — full HARD RULES bodies linked from AGENTS.md
#   build/scripts/           — runtime helpers from core/scripts/
#
# No <adapter> argument. No per-vendor builds. No adapter manifests. The output
# is the cross-tool standard; tools that natively read it (Codex, Cursor,
# Gemini CLI, DeepSeek TUI, Bob, Amp, Factory) consume it directly. Claude Code
# users opt in via claude-helpers/bootstrap.sh which writes a 1-line CLAUDE.md
# (`@AGENTS.md`) so Claude's @-import mechanism resolves to AGENTS.md content.
#
# Usage:
#   bin/forge-build                              build to ./build/
#   bin/forge-build --deploy <project>           build then copy outputs to <project>
#   bin/forge-build --deploy <project> --dry-run preview deploy without writing
#   bin/forge-build --help                       show this message
#
# See memory/maxima-pivot-plan.md for the architectural rationale.

set -euo pipefail

# --- Resolve paths ---
FORGE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILD_DIR="${BUILD_DIR:-$FORGE_ROOT/build}"

# --- Args ---
DEPLOY_TARGET=""
DRY_RUN=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --deploy)
      DEPLOY_TARGET="${2:-}"
      if [[ -z "$DEPLOY_TARGET" ]]; then
        echo "ERROR: --deploy requires a project path" >&2; exit 1
      fi
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    --help|-h)
      sed -n '2,21p' "${BASH_SOURCE[0]}" | sed 's|^# \{0,1\}||'
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      echo "Run 'bin/forge-build --help' for usage." >&2
      exit 1
      ;;
  esac
done

# --- Source dirs (sanity check) ---
SRC_SKILLS="$FORGE_ROOT/core/skills"
SRC_SCRIPTS="$FORGE_ROOT/core/scripts"
SRC_RULES="$FORGE_ROOT/core/rules"

for required in "$SRC_SKILLS" "$SRC_SCRIPTS" "$SRC_RULES"; do
  if [[ ! -d "$required" ]]; then
    echo "ERROR: required source directory missing: $required" >&2
    exit 1
  fi
done

echo "Generic Forge v2 build → $BUILD_DIR"
echo ""

# --- 1. Clean and recreate build dir ---
rm -rf "$BUILD_DIR"
mkdir -p "$BUILD_DIR/.agents/skills" "$BUILD_DIR/.agents/rules" "$BUILD_DIR/scripts"

# --- 2. Skills: copy core/skills/<name>/ → build/.agents/skills/<name>/ ---
SKILL_COUNT=0
for skill_dir in "$SRC_SKILLS"/*/; do
  [[ -d "$skill_dir" ]] || continue
  skill_name=$(basename "$skill_dir")
  cp -r "$skill_dir" "$BUILD_DIR/.agents/skills/"
  SKILL_COUNT=$((SKILL_COUNT + 1))
done
echo "  ✓ $SKILL_COUNT skills emitted to .agents/skills/"

# --- 3. Rules: copy core/rules/<name>.md → build/.agents/rules/<name>.md ---
RULE_COUNT=0
for rule_file in "$SRC_RULES"/*.md; do
  [[ -f "$rule_file" ]] || continue
  cp "$rule_file" "$BUILD_DIR/.agents/rules/"
  RULE_COUNT=$((RULE_COUNT + 1))
done
echo "  ✓ $RULE_COUNT rules emitted to .agents/rules/"

# --- 4. Scripts: copy core/scripts/*.sh → build/scripts/ ---
SCRIPT_COUNT=0
if compgen -G "$SRC_SCRIPTS"/*.sh > /dev/null; then
  cp "$SRC_SCRIPTS"/*.sh "$BUILD_DIR/scripts/"
  chmod +x "$BUILD_DIR/scripts"/*.sh
  SCRIPT_COUNT=$(ls "$BUILD_DIR/scripts/" | wc -l)
fi
echo "  ✓ $SCRIPT_COUNT scripts emitted to scripts/"

# --- 5. Compose AGENTS.md ---
AGENTS_MD="$BUILD_DIR/AGENTS.md"

# Helper: extract first descriptive paragraph from a markdown file.
# Skips H1 heading, then captures the first content block (blockquote or paragraph),
# stripping leading "> " from blockquote lines.
first_paragraph() {
  awk '
    /^# / { next }
    /^## / { exit }
    /^[[:space:]]*$/ { if (p) exit; next }
    {
      sub(/^> ?/, "")
      print
      p=1
    }
  ' "$1"
}

# Helper: extract a frontmatter field (first occurrence)
frontmatter_field() {
  local file="$1" field="$2"
  awk -v field="$field" '
    /^---/ { f++; next }
    f == 1 && $0 ~ "^"field":" {
      sub("^"field": *", "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$file"
}

{
  cat <<HEADER
# Forge — Agent Instructions

Forge is a tool-neutral knowledge + skills framework for AI coding agents. Skills (a.k.a. arts and masters) live in \`.agents/skills/<name>/SKILL.md\` per the [Open Agent Skills specification](https://agentskills.io/) (Anthropic, December 2025; cross-tool standard since January 2026). Most agents auto-discover them; some let you invoke explicitly via \`/<name>\` slash commands.

This file is the registry. Skill bodies live in \`.agents/skills/\`. HARD RULES live in \`.agents/rules/\`.
HEADER

  # Rules pointers (first paragraph + link)
  echo ""
  echo "## Rules"
  echo ""
  for rule_file in "$SRC_RULES"/*.md; do
    [[ -f "$rule_file" ]] || continue
    rule_name=$(basename "$rule_file" .md)
    summary=$(first_paragraph "$rule_file" | head -2 | tr '\n' ' ' | sed 's/  */ /g' | sed 's/ *$//')
    echo "**${rule_name}** — ${summary}"
    echo ""
    echo "→ Full rules: [.agents/rules/${rule_name}.md](.agents/rules/${rule_name}.md)"
    echo ""
  done

  # Model-hint guidance
  cat <<MODELHINT
## Model selection

Skills marked with \`<!-- model: opus -->\` benefit from a deep-reasoning model. On Codex CLI / DeepSeek TUI / Gemini CLI, switch via \`/model\` before invoking these skills.

MODELHINT

  # Skill registry table
  echo "## Skills"
  echo ""
  echo "| Skill | Description | Body |"
  echo "|---|---|---|"

  for skill_dir in "$SRC_SKILLS"/*/; do
    [[ -d "$skill_dir" ]] || continue
    skill_name=$(basename "$skill_dir")
    skill_file="$skill_dir/SKILL.md"
    [[ -f "$skill_file" ]] || continue

    desc=$(frontmatter_field "$skill_file" "description")
    # Strip the "TRIGGER when:" suffix and trim
    short_desc=$(echo "$desc" | sed 's/ TRIGGER when:.*$//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    # Truncate to 100 chars to keep table tidy
    if [[ ${#short_desc} -gt 100 ]]; then
      short_desc="${short_desc:0:97}..."
    fi
    [[ -z "$short_desc" ]] && short_desc="—"

    echo "| /${skill_name} | ${short_desc} | [.agents/skills/${skill_name}/SKILL.md](.agents/skills/${skill_name}/SKILL.md) |"
  done

  # Footer
  cat <<FOOTER

---

Generic Forge v2. Built from [forge-arcana/forge](https://github.com/forge-arcana/forge). See \`memory/maxima-pivot-plan.md\` for the architecture rationale.

For Claude Code users: \`bash <forge>/claude-helpers/bootstrap.sh <project>\` writes a 1-line \`CLAUDE.md\` containing \`@AGENTS.md\` so Claude's @-import mechanism reads this file. Other tools require no bootstrap.
FOOTER
} > "$AGENTS_MD"

# --- 6. Validate AGENTS.md size ---
agents_bytes=$(wc -c < "$AGENTS_MD")
agents_lines=$(wc -l < "$AGENTS_MD")
echo "  ✓ AGENTS.md composed (${agents_lines} lines, ${agents_bytes} bytes)"

if [[ $agents_bytes -gt 32768 ]]; then
  echo "  ⚠ AGENTS.md exceeds Codex's 32 KiB project_doc_max_bytes cap (${agents_bytes} bytes)" >&2
  echo "     Trim required — consider further progressive disclosure." >&2
fi
if [[ $agents_lines -gt 150 ]]; then
  echo "  ⚠ AGENTS.md exceeds 150-line target (${agents_lines} lines)" >&2
fi

echo ""
echo "Built: $BUILD_DIR"

# --- 7. Deploy if requested ---
if [[ -n "$DEPLOY_TARGET" ]]; then
  DEPLOY_TARGET=$(cd "$DEPLOY_TARGET" 2>/dev/null && pwd) || {
    echo "ERROR: deploy target does not exist: $DEPLOY_TARGET" >&2
    exit 1
  }

  if [[ "$DRY_RUN" -eq 1 ]]; then
    echo ""
    echo "DRY-RUN: would deploy:"
    echo "  $BUILD_DIR/AGENTS.md           → $DEPLOY_TARGET/AGENTS.md"
    echo "  $BUILD_DIR/.agents/skills/     → $DEPLOY_TARGET/.agents/skills/"
    echo "  $BUILD_DIR/.agents/rules/      → $DEPLOY_TARGET/.agents/rules/"
    echo "  $BUILD_DIR/scripts/            → $DEPLOY_TARGET/scripts/"
    exit 0
  fi

  echo ""
  echo "Deploying to $DEPLOY_TARGET ..."

  cp "$BUILD_DIR/AGENTS.md" "$DEPLOY_TARGET/AGENTS.md"

  mkdir -p "$DEPLOY_TARGET/.agents"
  rm -rf "$DEPLOY_TARGET/.agents/skills" "$DEPLOY_TARGET/.agents/rules"
  cp -r "$BUILD_DIR/.agents/skills" "$DEPLOY_TARGET/.agents/skills"
  cp -r "$BUILD_DIR/.agents/rules" "$DEPLOY_TARGET/.agents/rules"

  rm -rf "$DEPLOY_TARGET/scripts"
  cp -r "$BUILD_DIR/scripts" "$DEPLOY_TARGET/scripts"

  echo "  ✓ AGENTS.md, .agents/skills/, .agents/rules/, scripts/ deployed"
  echo ""
  echo "For Claude Code users: bash $FORGE_ROOT/claude-helpers/bootstrap.sh $DEPLOY_TARGET"
fi
