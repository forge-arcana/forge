#!/usr/bin/env bash
# bin/forge-build — assemble harness-specific deployable from tool-neutral core/
#
# Usage:
#   bin/forge-build <adapter>              build to ./build/<adapter>/
#   bin/forge-build <adapter> <out-dir>    build to specified output dir
#   bin/forge-build <adapter> --deploy     build, then copy output into the harness membrane
#   bin/forge-build <adapter> --deploy --dry-run    show what --deploy would do, no writes
#   bin/forge-build --list                 list known adapters
#
# Reads from:
#   core/skills/             tool-neutral skill sources
#   core/scripts/            tool-neutral runtime scripts
#   core/rules/              tool-neutral HARD RULES
#   adapters/<adapter>/      adapter manifest + adapter-only refs/scripts
#
# Writes to:
#   build/<adapter>/skills/  per-harness SKILL.md files (frontmatter injected)
#   build/<adapter>/scripts/ runtime scripts (core + adapter-specific)
#   build/<adapter>/refs/    adapter-specific reference docs
#
# --deploy targets:
#   claude-code:
#     ~/.claude/skills/        from build/claude-code/skills/
#     ~/.claude/scripts/       from build/claude-code/scripts/  (whole-dir overlay)
#     CLAUDE-rules-snippet.md  printed; the user merges manually into ~/.claude/CLAUDE.md
#   antigravity:
#     <project>/.agents/workflows/  from build/antigravity/workflows/  (workspace scope)
#     AGENTS.md                printed; user copies to project root (auto-loaded by Antigravity since v1.20.3)
#
# Phase 1+2: claude-code fully wired. Phase 3 (in progress): antigravity smoke test.
# Bob adapter is still a stub (manifest only).

set -euo pipefail

FORGE="$(cd "$(dirname "$0")/.." && pwd)"
ADAPTERS_DIR="$FORGE/adapters"

# ============================================================================
# CLI
# ============================================================================

if [[ $# -lt 1 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
  sed -n '2,/^$/p' "$0" | sed 's/^# //'
  exit 0
fi

if [[ "$1" == "--list" ]]; then
  echo "Known adapters:"
  for d in "$ADAPTERS_DIR"/*/; do
    name=$(basename "$d")
    if [[ -f "$d/manifest.yaml" ]]; then
      status=$(grep -E '^status:' "$d/manifest.yaml" 2>/dev/null | sed 's/status: *//' || echo "ready")
      echo "  $name  ($status)"
    fi
  done
  exit 0
fi

ADAPTER="$1"
shift

DEPLOY=0
DRY_RUN=0
OUT="$FORGE/build/$ADAPTER"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --deploy)   DEPLOY=1 ;;
    --dry-run)  DRY_RUN=1 ;;
    -*)         echo "ERROR: unknown flag '$1'" >&2; exit 1 ;;
    *)          OUT="$1" ;;
  esac
  shift
done

ADAPTER_DIR="$ADAPTERS_DIR/$ADAPTER"

if [[ ! -d "$ADAPTER_DIR" ]]; then
  echo "ERROR: unknown adapter '$ADAPTER'. Run: $0 --list" >&2
  exit 1
fi

if [[ ! -f "$ADAPTER_DIR/manifest.yaml" ]]; then
  echo "ERROR: $ADAPTER_DIR/manifest.yaml not found" >&2
  exit 1
fi

echo "Building $ADAPTER → $OUT"

# Clean output dir
rm -rf "$OUT"
mkdir -p "$OUT/skills" "$OUT/scripts" "$OUT/refs"

# ============================================================================
# claude-code adapter
# ============================================================================

build_claude_code() {
  local out="$OUT"

  # Hardcoded skill model overrides — mirrors adapters/claude-code/manifest.yaml.
  # Keep in sync with the manifest (or wire a yaml parser later).
  declare -A MODEL_COMMENT=(
    [forge]="sonnet | escalation: learning triage → spawn opus subagent"
    [smith]="opus"
    [wedge]="opus"
    [prime]="opus"
    [probe]="opus"
    [poke]="opus"
    [preen]="opus"
    [press]="opus"
    [pound]="opus"
    [pitch]="opus"
    [pry]="opus"
    [praise]="opus"
    [temper]="opus"
    [cicd]="sonnet"
    [qt]="haiku"
    [srs]="haiku"
    [monci]="haiku"
    [ponci]="haiku"
    [vsix]="haiku"
    [eli5]="haiku"
    [wawa]="haiku"
    [wrap]="haiku"
    # `dig` deliberately has no model comment
  )

  # 1. SKILLS
  local skill_count=0
  for skill_dir in "$FORGE"/core/skills/*/; do
    local name="$(basename "$skill_dir")"
    local src="$skill_dir/SKILL.md"
    local dest_dir="$out/skills/$name"
    [[ -f "$src" ]] || continue

    mkdir -p "$dest_dir"

    # Inject user-invocable: true into frontmatter, then add model HTML comment
    # after the closing ---.
    awk -v skill="$name" -v model="${MODEL_COMMENT[$name]:-}" '
      BEGIN { in_fm = 0; fm_seen = 0; injected = 0 }
      /^---$/ {
        if (in_fm == 0 && fm_seen == 0) {
          in_fm = 1; fm_seen = 1; print; next
        }
        if (in_fm == 1) {
          # closing fence — inject user-invocable just before it
          if (!injected) print "user-invocable: true"
          in_fm = 0
          print
          # add model HTML comment immediately after the fence if defined
          # (no blank line — matches the original Claude SKILL.md layout)
          if (model != "") {
            print "<!-- model: " model " -->"
          }
          next
        }
      }
      { print }
    ' "$src" > "$dest_dir/SKILL.md"

    # Copy any sibling refs (apprentice-system.md, protocol.md, etc.)
    for ref in "$skill_dir"*; do
      local refname="$(basename "$ref")"
      [[ "$refname" == "SKILL.md" ]] && continue
      [[ -f "$ref" ]] && cp "$ref" "$dest_dir/$refname"
    done

    skill_count=$((skill_count + 1))
  done
  echo "  ✓ $skill_count skills emitted"

  # 2. SCRIPTS — core (tool-neutral) first, then adapter-specific overlay
  local script_count=0
  for s in "$FORGE"/core/scripts/*.sh; do
    cp "$s" "$out/scripts/$(basename "$s")"
    script_count=$((script_count + 1))
  done
  if [[ -d "$ADAPTER_DIR/scripts" ]]; then
    for s in "$ADAPTER_DIR"/scripts/*.sh; do
      cp "$s" "$out/scripts/$(basename "$s")"
      script_count=$((script_count + 1))
    done
  fi
  echo "  ✓ $script_count scripts (core + adapter)"

  # 3. REFS — adapter-specific reference docs
  if [[ -d "$ADAPTER_DIR/refs" ]]; then
    cp -r "$ADAPTER_DIR/refs/." "$out/refs/"
    local ref_count=$(ls "$out/refs/" | wc -l)
    echo "  ✓ $ref_count adapter refs"
  fi

  # 4. RULES → CLAUDE.md composed from core/rules/
  # For Claude Code, the rules go into the user's ~/.claude/CLAUDE.md.
  # Phase 1 emits a composed file the user can review/install manually.
  local rules_out="$out/CLAUDE-rules-snippet.md"
  {
    echo "# Forge HARD RULES (composed for Claude Code)"
    echo ""
    echo "_Generated by bin/forge-build claude-code from core/rules/. Append to or merge_"
    echo "_into your ~/.claude/CLAUDE.md._"
    echo ""
    if [[ -f "$FORGE/core/rules/development-discipline.md" ]]; then
      cat "$FORGE/core/rules/development-discipline.md"
      echo ""
    fi
    if [[ -f "$FORGE/core/rules/forge-governance.md" ]]; then
      cat "$FORGE/core/rules/forge-governance.md"
      echo ""
    fi
  } > "$rules_out"
  echo "  ✓ rules composed → $(basename "$rules_out")"

  echo ""
  echo "Built: $out"
}

# ============================================================================
# bob adapter — Phase 3 smoke test
# ============================================================================

build_bob() {
  local out="$OUT"
  mkdir -p "$out/skills" "$out/commands" "$out/rules"

  # 1. SKILLS — Bob skills go in dir-per-skill: <name>/SKILL.md
  # Auto-activated by Bob based on the skill's description matching the user's request.
  local skill_count=0
  for skill_dir in "$FORGE"/core/skills/*/; do
    local name="$(basename "$skill_dir")"
    local src="$skill_dir/SKILL.md"
    [[ -f "$src" ]] || continue
    local dest_dir="$out/skills/$name"
    mkdir -p "$dest_dir"
    # Bob accepts core's name + description frontmatter unchanged.
    cp "$src" "$dest_dir/SKILL.md"
    # Copy any sibling refs alongside
    for ref in "$skill_dir"*; do
      local refname="$(basename "$ref")"
      [[ "$refname" == "SKILL.md" ]] && continue
      [[ -f "$ref" ]] && cp "$ref" "$dest_dir/$refname"
    done
    skill_count=$((skill_count + 1))
  done
  echo "  ✓ $skill_count skills emitted (auto-activation by description)"

  # 2. SLASH COMMANDS — Bob commands are flat <name>.md files in commands/
  # Filename = command name. Same body as the skill, so /eli5 explicit-invocation
  # mirrors the skill's auto-activation behavior.
  local cmd_count=0
  for skill_dir in "$FORGE"/core/skills/*/; do
    local name="$(basename "$skill_dir")"
    local src="$skill_dir/SKILL.md"
    [[ -f "$src" ]] || continue
    cp "$src" "$out/commands/$name.md"
    cmd_count=$((cmd_count + 1))
  done
  echo "  ✓ $cmd_count slash commands emitted (explicit /<name> invocation)"

  # 3. AGENTS.md — same composed cross-tool rules file. Bob auto-loads from project root.
  if [[ -d "$FORGE/core/rules" ]]; then
    {
      echo "# Forge Rules (composed for Bob / cross-tool AGENTS.md)"
      echo ""
      echo "_Generated by \`bin/forge-build bob\` from \`core/rules/\`._"
      echo "_Bob auto-loads AGENTS.md from project root by default. Same file works for Antigravity._"
      echo ""
      for f in "$FORGE"/core/rules/*.md; do
        cat "$f"
        echo ""
      done
    } > "$out/AGENTS.md"
    echo "  ✓ AGENTS.md composed"
  fi

  echo ""
  echo "Built: $out"
  echo ""
  echo "Smoke test (Phase 3 entry — /eli5 only, slash command path):"
  echo "  Source:      $out/commands/eli5.md"
  echo "  Drop into:   <project>/.bob/commands/eli5.md   (workspace scope)"
  echo "  OR:          ~/.bob/commands/eli5.md            (global scope)"
  echo "  Invoke:      /eli5 [something to explain]      (in Bob chat)"
}

# ============================================================================
# antigravity adapter — Phase 3 smoke test
# ============================================================================

build_antigravity() {
  local out="$OUT"
  mkdir -p "$out/workflows" "$out/rules"

  # 1. WORKFLOWS — Antigravity workflows are .md files in .agents/workflows/.
  # Forge core SKILL.md frontmatter (name + description) maps directly to
  # Antigravity's workflow frontmatter — no transformation needed.
  local workflow_count=0
  for skill_dir in "$FORGE"/core/skills/*/; do
    local name="$(basename "$skill_dir")"
    local src="$skill_dir/SKILL.md"
    [[ -f "$src" ]] || continue
    # Workflow filename = skill name + .md (e.g., eli5.md → invoked as /eli5)
    cp "$src" "$out/workflows/$name.md"
    workflow_count=$((workflow_count + 1))
  done
  echo "  ✓ $workflow_count workflows emitted"

  # 2. AGENTS.md — compose from core/rules/. Antigravity auto-loads this from
  # project root since v1.20.3. Same file serves Bob too (cross-tool standard).
  if [[ -d "$FORGE/core/rules" ]]; then
    {
      echo "# Forge Rules (composed for Antigravity / cross-tool AGENTS.md)"
      echo ""
      echo "_Generated by \`bin/forge-build antigravity\` from \`core/rules/\`._"
      echo "_Antigravity auto-loads AGENTS.md from project root since v1.20.3._"
      echo "_Same file works for Bob and any other harness that respects the cross-tool AGENTS.md standard._"
      echo ""
      for f in "$FORGE"/core/rules/*.md; do
        cat "$f"
        echo ""
      done
    } > "$out/AGENTS.md"
    echo "  ✓ AGENTS.md composed"
  fi

  # 3. Workspace rules — also emit individual rule files for the alternate
  # .agents/rules/ location (in case the user prefers per-rule files).
  if [[ -d "$FORGE/core/rules" ]]; then
    cp "$FORGE"/core/rules/*.md "$out/rules/"
    local rule_count=$(ls "$out/rules" | wc -l)
    echo "  ✓ $rule_count rule files emitted (alternate location)"
  fi

  echo ""
  echo "Built: $out"
  echo ""
  echo "Smoke test (Phase 3 entry — /eli5 only):"
  echo "  Source:      $out/workflows/eli5.md"
  echo "  Drop into:   <project>/.agents/workflows/eli5.md"
  echo "  Invoke:      /eli5 [something to explain]   (in Antigravity chat)"
}

# ============================================================================
# Dispatch
# ============================================================================

case "$ADAPTER" in
  claude-code) build_claude_code ;;
  bob)         build_bob ;;
  antigravity) build_antigravity ;;
  *)           echo "ERROR: build logic not implemented for $ADAPTER" >&2; exit 1 ;;
esac

# ============================================================================
# Deploy
# ============================================================================

deploy_claude_code() {
  local membrane="${FORGE_MEMBRANE:-$HOME/.claude}"
  local skills_target="$membrane/skills"
  local scripts_target="$membrane/scripts"

  echo ""
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "Deploy plan (claude-code) — dry run, no writes:"
  else
    echo "Deploying to $membrane:"
  fi

  # Skills: per-skill rsync-style overlay (remove dest first to avoid cp nesting)
  for skill_dir in "$OUT"/skills/*/; do
    local name="$(basename "$skill_dir")"
    local dest="$skills_target/$name"
    if [[ $DRY_RUN -eq 1 ]]; then
      if [[ -d "$dest" ]]; then echo "  REPLACE $dest"; else echo "  CREATE  $dest"; fi
    else
      mkdir -p "$skills_target"
      rm -rf "$dest"
      cp -r "$skill_dir" "$dest"
    fi
  done

  # Scripts: deploy ONLY the WA-001 trio that hooks invoke by absolute path.
  # Core scripts (forge-status.sh, fold-evidence.sh, etc.) stay in the forge
  # repo — skills invoke them via `bash <forge>/core/scripts/...`. Deploying
  # them to the membrane would create dead duplicates.
  local DEPLOYED_SCRIPTS=(
    agent-token-warmup.sh
    agent-token-scheduler.sh
    user-agent-preflight.sh
  )
  for sname in "${DEPLOYED_SCRIPTS[@]}"; do
    local s="$OUT/scripts/$sname"
    [[ -f "$s" ]] || continue
    local dest="$scripts_target/$sname"
    if [[ $DRY_RUN -eq 1 ]]; then
      if [[ -f "$dest" ]]; then echo "  REPLACE $dest"; else echo "  CREATE  $dest"; fi
    else
      mkdir -p "$scripts_target"
      cp "$s" "$dest"
      chmod +x "$dest"
    fi
  done

  if [[ $DRY_RUN -eq 1 ]]; then
    echo ""
    echo "Rules snippet (would be printed for manual merge): $OUT/CLAUDE-rules-snippet.md"
  else
    echo ""
    echo "Deploy complete. Manual step remaining:"
    echo "  Review $OUT/CLAUDE-rules-snippet.md and merge HARD RULES into $membrane/CLAUDE.md"
  fi
}

deploy_antigravity() {
  # Antigravity workflows deploy at workspace scope (the project the user has
  # open in Antigravity — typically the forge repo itself). Global scope
  # (~/.gemini/antigravity/global_workflows/) lives on the Windows host when
  # Antigravity is a Windows IDE; that path is up to the user to copy across.
  # AGENTS.md is NOT auto-merged — the user reviews and copies manually.

  local target="${ANTIGRAVITY_WORKSPACE:-$FORGE}/.agents/workflows"

  echo ""
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "Deploy plan (antigravity, workspace=$ANTIGRAVITY_WORKSPACE${ANTIGRAVITY_WORKSPACE:+, default=$FORGE}) — dry run:"
  else
    echo "Deploying to $target:"
  fi

  for w in "$OUT"/workflows/*.md; do
    [[ -f "$w" ]] || continue
    local wname="$(basename "$w")"
    local dest="$target/$wname"
    if [[ $DRY_RUN -eq 1 ]]; then
      if [[ -f "$dest" ]]; then echo "  REPLACE $dest"; else echo "  CREATE  $dest"; fi
    else
      mkdir -p "$target"
      cp "$w" "$dest"
    fi
  done

  echo ""
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "AGENTS.md (manual merge target): $OUT/AGENTS.md  →  <project-root>/AGENTS.md"
  else
    echo "Workflows deployed. Manual step remaining:"
    echo "  Review $OUT/AGENTS.md and copy to <project>/AGENTS.md if you want global rules"
    echo "  (Antigravity auto-loads AGENTS.md from project root since v1.20.3)"
  fi
}

if [[ $DEPLOY -eq 1 ]]; then
  case "$ADAPTER" in
    claude-code) deploy_claude_code ;;
    antigravity) deploy_antigravity ;;
    *)           echo "ERROR: --deploy not implemented for $ADAPTER" >&2; exit 1 ;;
  esac
fi
